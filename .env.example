# Horizon Cinemas Booking System — Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hcbs
DB_USER=root
DB_PASSWORD=your_password_here

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Application
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True

# Groq Cloud AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_SECONDARY=openai/gpt-oss-120b
